# Copy to .env.local for local dev, or set in Cloudflare Pages → Settings → Environment variables

# Canonical site URL (used in sitemap, Open Graph, JSON-LD)
# Production example: https://life.hottoolsbox.com
NEXT_PUBLIC_SITE_URL=https://life.hottoolsbox.com

# Google Analytics 4 (optional — only loads after cookie consent)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-FM86YNWM13

# Set automatically by Cloudflare Pages during build (do not set manually)
# CF_PAGES=1
